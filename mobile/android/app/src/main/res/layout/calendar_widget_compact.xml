<?xml version="1.0" encoding="utf-8"?>
<!-- Compact layout for small widgets (4×2).
     Shows account/month navigation + today's date + monthly change. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp"
    android:gravity="center_vertical">

    <!-- Account + month navigation (combined row) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Account nav -->
        <ImageButton
            android:id="@+id/btn_prev_account"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Previous account" />

        <TextView
            android:id="@+id/widget_account_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Account"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btn_next_account"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Next account" />

        <View android:layout_width="1dp" android:layout_height="16dp"
            android:layout_marginHorizontal="6dp" android:background="#44FFFFFF" />

        <!-- Month nav -->
        <ImageButton
            android:id="@+id/btn_prev_month"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_rew"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Previous month" />

        <TextView
            android:id="@+id/widget_month_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:text="2026-03"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_next_month"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_ff"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Next month" />

    </LinearLayout>

    <!-- Today + Monthly Change row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_compact_row_bg"
        android:padding="8dp">

        <!-- Today's date circle -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_date_circle">

            <TextView
                android:id="@+id/widget_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_weekday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MON"
                android:textColor="#CCFFFFFF"
                android:textSize="8sp"
                android:textAllCaps="true" />

        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp"
            android:layout_marginHorizontal="10dp" android:background="#44FFFFFF" />

        <!-- Monthly change -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Change"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_monthly_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
