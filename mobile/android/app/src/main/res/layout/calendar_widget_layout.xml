        <TextView android:id="@+id/day_3_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_3_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_3_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_3_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
