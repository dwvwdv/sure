<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Account selector row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/btn_prev_account"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous account"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingRight="4dp">

            <TextView
                android:id="@+id/widget_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:ellipsize="end"
                android:maxLines="1"
                android:gravity="center" />

            <TextView
                android:id="@+id/widget_account_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#6B7280"
                android:gravity="center" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_next_account"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next account"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Month navigation row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/btn_prev_month"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous month"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/widget_month_year"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:textAlignment="center" />

        <ImageView
            android:id="@+id/btn_next_month"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next month"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Monthly total -->
    <TextView
        android:id="@+id/widget_monthly_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:paddingBottom="6dp" />

    <!-- Weekday headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="2dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textAlignment="center" android:textSize="10sp" android:textColor="#9CA3AF" android:textStyle="bold" />
    </LinearLayout>

    <!-- Calendar grid (6 rows) -->
