        <TextView android:id="@+id/day_2_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_2_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
