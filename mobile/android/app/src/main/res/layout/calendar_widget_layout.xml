    <LinearLayout android:id="@+id/week_row_3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/day_3_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
