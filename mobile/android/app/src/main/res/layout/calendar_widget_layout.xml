        <TextView android:id="@+id/day_4_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_4_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_4_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
        <TextView android:id="@+id/day_4_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/week_row_5" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/day_5_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="10sp" android:background="@drawable/day_cell_bg" android:layout_margin="1dp" />
