<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header: Account name and nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageButton
            android:id="@+id/btn_prev_account"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Previous account" />

        <TextView
            android:id="@+id/widget_account_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Account"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btn_next_account"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Next account" />

    </LinearLayout>

    <!-- Month navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageButton
            android:id="@+id/btn_prev_month"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_rew"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Previous month" />

        <TextView
            android:id="@+id/widget_month_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2026-01"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btn_next_month"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_ff"
            android:background="@null"
            android:tint="#CCFFFFFF"
            android:contentDescription="Next month" />

    </LinearLayout>

    <!-- Weekday labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="S" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="M" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="T" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="W" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="T" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="F" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="S" android:textColor="#AAFFFFFF" android:textSize="9sp" android:gravity="center" android:textStyle="bold"/>

    </LinearLayout>

    <!-- Calendar grid (GridView populated by RemoteViewsService) -->
    <GridView
        android:id="@+id/widget_calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="7"
        android:horizontalSpacing="2dp"
        android:verticalSpacing="2dp"
        android:scrollbars="none" />

    <!-- Monthly total footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Monthly Change"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_monthly_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
